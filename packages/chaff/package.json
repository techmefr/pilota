{
    "name": "chaff",
    "version": "0.0.1",
    "description": "Schema-driven mock/fallback engine — validate fixtures against a Zod schema, optional MirageJS server.",
    "type": "module",
    "license": "MIT",
    "author": "techmefr",
    "homepage": "https://github.com/techmefr/pilota/tree/main/packages/chaff#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/techmefr/pilota.git",
        "directory": "packages/chaff"
    },
    "keywords": [
        "mock",
        "fixture",
        "zod",
        "miragejs",
        "offline",
        "fallback"
    ],
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "default": "./dist/index.mjs"
        }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "unbuild",
        "test": "vitest run",
        "dev": "unbuild --stub"
    },
    "peerDependencies": {
        "miragejs": "^0.1.47",
        "zod": "^3.23.8"
    },
    "peerDependenciesMeta": {
        "miragejs": {
            "optional": true
        }
    },
    "devDependencies": {
        "miragejs": "^0.1.47",
        "unbuild": "^2.0.0",
        "vitest": "^2.0.0",
        "zod": "^3.23.8",
        "typescript": "^5.5.0"
    }
}
