{
    "name": "beepr",
    "version": "0.0.1",
    "description": "Tiny typed event/notify engine — one handler contract, composable adapters.",
    "type": "module",
    "license": "MIT",
    "author": "techmefr",
    "homepage": "https://github.com/techmefr/pilota/tree/main/packages/beepr#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/techmefr/pilota.git",
        "directory": "packages/beepr"
    },
    "keywords": [
        "events",
        "notify",
        "hookable",
        "typed",
        "adapter"
    ],
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "default": "./dist/index.mjs"
        }
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "unbuild",
        "test": "vitest run",
        "dev": "unbuild --stub"
    },
    "dependencies": {
        "hookable": "^5.5.3"
    },
    "devDependencies": {
        "unbuild": "^2.0.0",
        "vitest": "^2.0.0",
        "typescript": "^5.5.0"
    }
}
