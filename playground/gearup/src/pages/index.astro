---
import Layout from '../layouts/Layout.astro'
import Dashboard from '../components/Dashboard'
import { fetchPcProfiles } from '../functional/Gearup/fetchPcProfiles'
import { fetchInventory } from '../functional/Gearup/fetchInventory'
import { fetchRepairs } from '../functional/Gearup/fetchRepairs'
import { fetchOrders } from '../functional/Gearup/fetchOrders'
import { fetchAlerts } from '../functional/Gearup/fetchAlerts'

let profiles = await fetchPcProfiles().catch(() => [])
let inventory = await fetchInventory()
let repairs = await fetchRepairs()
let orders = await fetchOrders()
let alerts = await fetchAlerts()
---

<Layout title="Tableau de bord" currentPath="/">
    <Dashboard
        client:load
        profiles={profiles}
        inventory={inventory}
        repairs={repairs}
        orders={orders}
        alerts={alerts}
    />
</Layout>
