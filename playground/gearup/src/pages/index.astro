---
import { createGearupPilota, type PcProfile } from '../lib/pilota'

const CYCLE = '2024 – 2027'
const laravelUrl = import.meta.env.LARAVEL_API_URL ?? 'http://host.docker.internal:8000/api'

let profiles: PcProfile[] = []
let fetchError = false

try {
    const pilota = createGearupPilota(laravelUrl)
    const result = await pilota.lomkit.pcProfiles.get()
    profiles = (result.data as PcProfile[]) ?? []
} catch {
    fetchError = true
}

const totalCount = profiles.reduce((s, p) => s + p.total, 0)
const totalStock = profiles.reduce((s, p) => s + p.stock, 0)
const totalOrder = profiles.reduce((s, p) => s + Math.max(0, p.total - p.stock), 0)

function toOrder(p: PcProfile) { return Math.max(0, p.total - p.stock) }

const modelNames = [...new Set(profiles.map(p => p.model_name))]
const models = modelNames.map(name => {
    const p = profiles.find(p => p.model_name === name)!
    return {
        name,
        tier: p.model_tier,
        cpu: p.cpu,
        ram: p.ram,
        storage: p.storage,
        gpu: p.gpu,
        profileRoles: profiles.filter(p => p.model_name === name).map(p => p.role),
    }
})
---

<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Gearup — Config HP XEFI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            /* Dark (default) — XEFI */
            --bg: #0a0a0e;
            --surface: #111116;
            --surface-2: #18181f;
            --border: #1e1e28;
            --border-strong: #2a2a38;

            --primary: #ff2420;
            --primary-dim: rgba(255, 36, 32, 0.12);
            --primary-hover: rgba(255, 36, 32, 0.2);

            --text: #f2f2f6;
            --text-secondary: #8f8fa8;
            --muted: #5a5a72;

            --green: #52B788;
            --green-dim: rgba(82, 183, 136, 0.12);
            --amber: #e8924a;
            --amber-dim: rgba(232, 146, 74, 0.12);

            --shadow: 0 8px 40px rgba(0,0,0,0.6);
            --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            --radius: 0.75rem;
            --radius-lg: 1rem;
            color-scheme: dark;
        }

        [data-theme="light"] {
            --bg: #f3f3f7;
            --surface: #ffffff;
            --surface-2: #f0f0f6;
            --border: #e0e0ec;
            --border-strong: #c8c8dc;

            --primary: #e10600;
            --primary-dim: rgba(225, 6, 0, 0.08);
            --primary-hover: rgba(225, 6, 0, 0.15);

            --text: #0e0e14;
            --text-secondary: #4a4a60;
            --muted: #8080a0;

            --green: #2e7d5a;
            --green-dim: rgba(46, 125, 90, 0.1);
            --amber: #b85c00;
            --amber-dim: rgba(184, 92, 0, 0.1);

            --shadow: 0 4px 20px rgba(10,10,30,0.1);
            color-scheme: light;
        }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--font);
            font-size: 14px;
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            min-height: 100vh;
            transition: background 0.2s, color 0.2s;
        }

        a { color: var(--primary); text-decoration: none; }
        a:hover { text-decoration: underline; }

        /* ── Theme toggle ───────────────────────────── */
        .theme-btn {
            width: 2rem;
            height: 2rem;
            border-radius: 50%;
            border: 1.5px solid var(--border);
            background: var(--surface-2);
            color: var(--muted);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: border-color 0.15s, color 0.15s;
            flex-shrink: 0;
        }

        .theme-btn:hover { border-color: var(--primary); color: var(--primary); }
        .theme-btn:active { transform: scale(0.92); }

        /* ── Topbar ─────────────────────────────────── */
        .topbar {
            height: 3.25rem;
            background: var(--surface);
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 10;
            transition: background 0.2s, border-color 0.2s;
        }

        .brand { display: flex; align-items: center; gap: 0.875rem; }

        .brand-xefi {
            font-size: 1rem;
            font-weight: 900;
            letter-spacing: -0.04em;
            color: var(--primary);
        }

        .brand-sep { width: 1px; height: 1rem; background: var(--border-strong); }

        .brand-name {
            font-size: 0.95rem;
            font-weight: 700;
            color: var(--text);
            letter-spacing: -0.02em;
        }

        .topbar-right { display: flex; align-items: center; gap: 0.75rem; }

        .cycle-badge {
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--muted);
            border: 1px solid var(--border);
            border-radius: 99px;
            padding: 0.25rem 0.75rem;
            letter-spacing: 0.04em;
        }

        .hub-link { font-size: 0.8rem; color: var(--muted); }
        .hub-link:hover { color: var(--text); text-decoration: none; }

        /* ── Main ───────────────────────────────────── */
        main {
            max-width: 1100px;
            margin: 0 auto;
            padding: 2.5rem 2rem 4rem;
            display: flex;
            flex-direction: column;
            gap: 2.5rem;
        }

        .page-title {
            font-size: 1.75rem;
            font-weight: 900;
            letter-spacing: -0.04em;
        }

        .page-sub {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-top: 0.25rem;
        }

        /* ── Stats ──────────────────────────────────── */
        .stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1.25rem 1.5rem;
            transition: background 0.2s, border-color 0.2s;
        }

        .stat-label {
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--muted);
            margin-bottom: 0.5rem;
        }

        .stat-value {
            font-size: 2.25rem;
            font-weight: 900;
            letter-spacing: -0.04em;
            line-height: 1;
        }

        .stat-value.v-default { color: var(--text); }
        .stat-value.v-green   { color: var(--green); }
        .stat-value.v-amber   { color: var(--amber); }

        .stat-sub { font-size: 0.75rem; color: var(--text-secondary); margin-top: 0.35rem; }

        /* ── Section title ──────────────────────────── */
        .section-title {
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--muted);
            margin-bottom: 1rem;
        }

        /* ── HP Models ──────────────────────────────── */
        .models-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }

        .model-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            transition: background 0.2s, border-color 0.2s;
        }

        .model-card.perf {
            border-color: rgba(255, 36, 32, 0.3);
            background: linear-gradient(135deg, var(--surface) 0%, var(--primary-dim) 100%);
        }

        [data-theme="light"] .model-card.perf {
            border-color: rgba(225, 6, 0, 0.25);
        }

        .model-tier {
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            padding: 0.2rem 0.6rem;
            border-radius: 99px;
            display: inline-flex;
        }

        .tier-perf {
            background: var(--primary-dim);
            color: var(--primary);
            border: 1px solid rgba(255,36,32,0.25);
        }

        .tier-std {
            background: var(--surface-2);
            color: var(--text-secondary);
            border: 1px solid var(--border);
        }

        .model-name {
            font-size: 1rem;
            font-weight: 800;
            letter-spacing: -0.02em;
            margin-top: 0.25rem;
        }

        .model-specs { display: flex; flex-direction: column; gap: 0.4rem; }

        .spec-row {
            display: flex;
            justify-content: space-between;
            font-size: 0.8rem;
        }

        .spec-key { color: var(--muted); }
        .spec-val { color: var(--text-secondary); font-weight: 500; }

        .model-profiles {
            display: flex;
            flex-wrap: wrap;
            gap: 0.375rem;
            padding-top: 0.5rem;
            border-top: 1px solid var(--border);
        }

        .profile-tag {
            font-size: 0.7rem;
            font-weight: 600;
            padding: 0.2rem 0.6rem;
            border-radius: 99px;
            background: var(--surface-2);
            color: var(--text-secondary);
            border: 1px solid var(--border);
        }

        /* ── Profiles list ──────────────────────────── */
        .col-label {
            font-size: 0.65rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: var(--muted);
            padding: 0 1.25rem 0.5rem;
            display: grid;
            grid-template-columns: 1fr 6rem 10rem 4rem 4rem 8rem;
            gap: 1rem;
        }

        .profiles-list { display: flex; flex-direction: column; gap: 0.5rem; }

        .profile-row {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem 1.25rem;
            display: grid;
            grid-template-columns: 1fr 6rem 10rem 4rem 4rem 8rem;
            align-items: center;
            gap: 1rem;
            transition: border-color 0.15s, background 0.2s;
        }

        .profile-row:hover { border-color: var(--border-strong); }

        .profile-role {
            font-size: 0.9rem;
            font-weight: 700;
            letter-spacing: -0.01em;
        }

        .model-ref { font-size: 0.7rem; color: var(--muted); margin-top: 0.15rem; }

        .spec-chips { display: flex; flex-wrap: wrap; gap: 0.3rem; }

        .chip {
            font-size: 0.68rem;
            font-weight: 600;
            padding: 0.2rem 0.55rem;
            border-radius: 99px;
            background: var(--surface-2);
            color: var(--text-secondary);
            border: 1px solid var(--border);
            white-space: nowrap;
        }

        .chip-perf {
            background: var(--primary-dim);
            color: var(--primary);
            border-color: rgba(255,36,32,0.2);
        }

        [data-theme="light"] .chip-perf {
            border-color: rgba(225,6,0,0.2);
        }

        .count-val { font-size: 1.1rem; font-weight: 800; letter-spacing: -0.02em; }
        .stock-val { font-size: 1rem; font-weight: 700; color: var(--green); }

        .order-badge {
            display: inline-flex;
            align-items: center;
            font-size: 0.72rem;
            font-weight: 600;
            padding: 0.3rem 0.7rem;
            border-radius: 99px;
        }

        .badge-order {
            background: var(--amber-dim);
            color: var(--amber);
            border: 1px solid rgba(232,146,74,0.25);
        }

        [data-theme="light"] .badge-order { border-color: rgba(184,92,0,0.25); }

        .badge-ok {
            background: var(--green-dim);
            color: var(--green);
            border: 1px solid rgba(82,183,136,0.25);
        }

        [data-theme="light"] .badge-ok { border-color: rgba(46,125,90,0.25); }

        .footer-note {
            font-size: 0.75rem;
            color: var(--muted);
            padding-top: 1rem;
            border-top: 1px solid var(--border);
        }

        @media (max-width: 768px) {
            .stats { grid-template-columns: 1fr; }
            .models-grid { grid-template-columns: 1fr; }
            .col-label { display: none; }
            .profile-row { grid-template-columns: 1fr 1fr; }
        }

        @media (prefers-reduced-motion: reduce) {
            body, .topbar, .stat-card, .model-card, .profile-row { transition: none; }
        }
    </style>
</head>
<body>

<nav class="topbar">
    <div class="brand">
        <span class="brand-xefi">XEFI</span>
        <span class="brand-sep"></span>
        <span class="brand-name">Gearup</span>
    </div>
    <div class="topbar-right">
        <span class="cycle-badge">Cycle {CYCLE}</span>
        <button class="theme-btn" id="theme-toggle" aria-label="Basculer le thème">
            <svg id="icon-sun" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none">
                <circle cx="12" cy="12" r="5"/>
                <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
                <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
                <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
            </svg>
            <svg id="icon-moon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
            </svg>
        </button>
        <a href="http://localhost:9999" class="hub-link">← Hub</a>
    </div>
</nav>

<main>

    <div>
        <h1 class="page-title">Configuration postes HP</h1>
        <p class="page-sub">Configs recommandées par profil · Générées au build depuis Laravel · 2 modèles max par cycle · Cycle {CYCLE}</p>
    </div>

    {fetchError && (
        <div style="background:var(--primary-dim);border:1px solid var(--primary);border-radius:var(--radius);padding:1rem 1.25rem;font-size:0.85rem;color:var(--primary)">
            Impossible de joindre Laravel ({laravelUrl}) — vérifier que le backend tourne.
        </div>
    )}

    {!fetchError && profiles.length === 0 && (
        <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:3rem;text-align:center;color:var(--muted)">
            Aucun profil — base de données vide ou seeder non exécuté.
        </div>
    )}

    {profiles.length > 0 && (
        <>
    <div class="stats">
        <div class="stat-card">
            <div class="stat-label">Postes total</div>
            <div class="stat-value v-default">{totalCount}</div>
            <div class="stat-sub">{profiles.length} profils · via Pilota / Lomkit</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">En stock</div>
            <div class="stat-value v-green">{totalStock}</div>
            <div class="stat-sub">prêts à déployer</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">À commander</div>
            <div class="stat-value v-amber">{totalOrder}</div>
            <div class="stat-sub">postes manquants</div>
        </div>
    </div>

    <div>
        <div class="section-title">Modèles du cycle {CYCLE}</div>
        <div class="models-grid">
            {models.map(m => (
                <div class={`model-card ${m.tier === 'performance' ? 'perf' : ''}`}>
                    <div>
                        <span class={`model-tier ${m.tier === 'performance' ? 'tier-perf' : 'tier-std'}`}>
                            {m.tier === 'performance' ? 'Performance' : 'Standard'}
                        </span>
                        <div class="model-name">{m.name}</div>
                    </div>
                    <div class="model-specs">
                        <div class="spec-row"><span class="spec-key">Processeur</span><span class="spec-val">{m.cpu}</span></div>
                        <div class="spec-row"><span class="spec-key">Mémoire</span><span class="spec-val">{m.ram}</span></div>
                        <div class="spec-row"><span class="spec-key">Stockage</span><span class="spec-val">{m.storage}</span></div>
                        <div class="spec-row"><span class="spec-key">GPU</span><span class="spec-val">{m.gpu}</span></div>
                    </div>
                    <div class="model-profiles">
                        {m.profileRoles.map(role => <span class="profile-tag">{role}</span>)}
                    </div>
                </div>
            ))}
        </div>
    </div>

    <div>
        <div class="section-title">Configs par profil</div>
        <div class="col-label">
            <span>Profil</span>
            <span>Modèle</span>
            <span>Spécifications</span>
            <span>Postes</span>
            <span>Stock</span>
            <span>Commande</span>
        </div>
        <div class="profiles-list">
            {profiles.map(p => {
                const order = toOrder(p)
                const isPerf = p.model_tier === 'performance'
                return (
                    <div class="profile-row">
                        <div>
                            <div class="profile-role">{p.role}</div>
                            <div class="model-ref">{p.model_name}</div>
                        </div>
                        <div>
                            <span class={`chip ${isPerf ? 'chip-perf' : ''}`}>{isPerf ? 'Performance' : 'Standard'}</span>
                        </div>
                        <div class="spec-chips">
                            <span class="chip">{p.screen_spec}</span>
                            <span class="chip">RAM {p.profile_ram}</span>
                        </div>
                        <div class="count-val">{p.total}</div>
                        <div class="stock-val">{p.stock}</div>
                        <div>
                            {order > 0
                                ? <span class="order-badge badge-order">+{order} à commander</span>
                                : <span class="order-badge badge-ok">À jour</span>
                            }
                        </div>
                    </div>
                )
            })}
        </div>
    </div>

    <p class="footer-note">
        Données via Pilota SDK · LomkitDriver → Laravel Interact · Astro 5 SSG · Cycle {CYCLE} · 2 modèles HP max
    </p>
        </>
    )}

</main>

<script>
    const html = document.documentElement
    const btn = document.getElementById('theme-toggle')
    const iconSun = document.getElementById('icon-sun') as HTMLElement
    const iconMoon = document.getElementById('icon-moon') as HTMLElement

    function applyTheme(theme: string) {
        html.setAttribute('data-theme', theme)
        iconSun.style.display = theme === 'light' ? 'block' : 'none'
        iconMoon.style.display = theme === 'light' ? 'none' : 'block'
    }

    const saved = localStorage.getItem('gearup-theme')
    const preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark'
    applyTheme(saved ?? preferred)

    btn?.addEventListener('click', () => {
        const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark'
        localStorage.setItem('gearup-theme', next)
        applyTheme(next)
    })
</script>

</body>
</html>
