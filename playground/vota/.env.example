# ──────────────────────────────────────────────────────────────────────────
# SERVER-ONLY — NEVER prefix with PUBLIC_. Read only in +page.server.ts.
# The Hasura admin secret bypasses ALL permissions, so it must never be
# exposed to the browser. SvelteKit only inlines PUBLIC_* vars into the client.
# ──────────────────────────────────────────────────────────────────────────
# Hasura endpoint used by server-side loads/actions (+page.server.ts).
NHOST_GRAPHQL_URL=http://localhost:8080/v1/graphql
# Server-only admin secret — NEVER prefix with PUBLIC_.
NHOST_ADMIN_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# CLIENT-PUBLIC — inlined into the browser bundle. No secrets here.
# ──────────────────────────────────────────────────────────────────────────
# Hasura endpoint for browser-side realtime WS subscriptions + live mutations.
# Connects with NO admin secret — requires a Hasura `anonymous` (public) role
# with the appropriate permissions on the planning_* tables.
PUBLIC_NHOST_GRAPHQL_URL=http://localhost:8080/v1/graphql

# Tolgee self-hosted — projet vota
VITE_TOLGEE_API_URL=http://localhost:8085
VITE_TOLGEE_API_KEY=
