{
  "type": "replace_metadata",
  "args": {
    "version": 3,
    "sources": [
      {
        "name": "default",
        "kind": "postgres",
        "configuration": {
          "connection_info": {
            "database_url": { "from_env": "HASURA_GRAPHQL_DATABASE_URL" },
            "isolation_level": "read-committed",
            "use_prepared_statements": false
          }
        },
        "tables": [
          {
            "table": { "schema": "public", "name": "users" },
            "select_permissions": [
              { "role": "public", "permission": { "columns": "*", "filter": {} } }
            ]
          },
          {
            "table": { "schema": "public", "name": "posts" },
            "select_permissions": [
              { "role": "public", "permission": { "columns": "*", "filter": {} } }
            ]
          },
          {
            "table": { "schema": "public", "name": "messages" },
            "select_permissions": [
              { "role": "public", "permission": { "columns": "*", "filter": {} } }
            ],
            "insert_permissions": [
              { "role": "public", "permission": { "columns": ["room_id", "content", "author"], "check": {} } }
            ]
          },
          {
            "table": { "schema": "public", "name": "products" },
            "select_permissions": [
              { "role": "public", "permission": { "columns": "*", "filter": {} } }
            ]
          }
        ]
      }
    ]
  }
}
