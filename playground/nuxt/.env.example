# ──────────────────────────────────────────────────────────────────────────
# SERVER-ONLY — NEVER prefix these with VITE_ / PUBLIC_ / NUXT_PUBLIC_.
# Any VITE_*/PUBLIC_* var is inlined into the client bundle. The Hasura admin
# secret bypasses ALL permissions, so it must stay server-side only. It is read
# by the Nitro proxy route (server/api/graphql.post.ts) and injected as the
# x-hasura-admin-secret header server-side.
# ──────────────────────────────────────────────────────────────────────────
# Real Hasura endpoint the server proxy forwards to.
NHOST_ENDPOINT=http://localhost:1337/v1/graphql
# Server-only admin secret — NEVER prefix with VITE_/PUBLIC_.
NHOST_ADMIN_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# CLIENT-PUBLIC — inlined into the browser bundle. No secrets here.
# ──────────────────────────────────────────────────────────────────────────
# Lomkit / Laravel (REST)
VITE_LOMKIT_BASE_URL=http://localhost:8000/api

# Supabase (Realtime) — anon key is safe to expose by design (RLS-protected)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=

# Tolgee self-hosted — projet shoplab (ID 39)
# Instance partagée : http://localhost:8085 — admin/admin1234
NUXT_PUBLIC_TOLGEE_API_URL=http://localhost:8085
NUXT_PUBLIC_TOLGEE_API_KEY=
