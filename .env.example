# Pilota infrastructure host-port overrides.
#
# Copy to `.env` and uncomment ONLY if ports 80/443 are already taken on your
# machine (e.g. another Traefik/web server). On a clean machine the defaults
# give port-free URLs: https://<branch>-<svc>.localhost
#
# docker compose reads this file automatically; `make up` / `make proxy-up`
# pick it up too (the Makefile includes it when present).

# HTTP entrypoint host port (redirects to HTTPS). Default: 80
# PILOTA_HTTP_PORT=80

# HTTPS entrypoint host port (mkcert TLS). Default: 443
# PILOTA_HTTPS_PORT=443

# Traefik dashboard host port. Default: 8090
# PILOTA_DASHBOARD_PORT=8090
